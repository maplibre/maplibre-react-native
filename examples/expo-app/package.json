{
  "private": true,
  "name": "@maplibre/expo-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "lint": "eslint --ext js,ts,tsx .",
    "build": "expo prebuild",
    "export": "expo export --output-dir ./build --platform all",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas-build-pre-install": "npm install --global pnpm@7.x",
    "eas-build-post-install": "pnpm run -w build:mobile"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/vector-icons": "^13.0.0",
    "@mapbox/geo-viewport": "^0.5.0",
    "@maplibre/maplibre-react-native": "file:../../",
    "@react-native-community/netinfo": "^9.3.10",
    "@react-native-masked-view/masked-view": "^0.2.9",
    "@react-navigation/drawer": "^6.6.3",
    "@react-navigation/native": "^6.1.7",
    "@react-navigation/stack": "^6.3.17",
    "@turf/along": "^6.5.0",
    "@turf/bbox-polygon": "^6.5.0",
    "@turf/distance": "^6.5.0",
    "@turf/helpers": "^6.5.0",
    "@turf/length": "^6.5.0",
    "@turf/nearest-point-on-line": "6.5.0",
    "debounce": "^1.2.0",
    "expo": "^49.0.2",
    "expo-dev-client": "~2.4.5",
    "expo-font": "~11.4.0",
    "expo-linking": "~5.0.2",
    "expo-location": "^16.1.0",
    "expo-router": "^2.0.12",
    "expo-screen-orientation": "~6.0.5",
    "expo-splash-screen": "~0.20.4",
    "expo-status-bar": "~1.6.0",
    "expo-system-ui": "~2.4.0",
    "expo-updates": "~0.18.12",
    "expo-web-browser": "~12.3.2",
    "fbjs": "^3.0.0",
    "moment": "^2.24.0",
    "prop-types": "^15.7.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.72.1",
    "react-native-elements": "^3.4.2",
    "react-native-gesture-handler": "~2.12.0",
    "react-native-reanimated": "~3.3.0",
    "react-native-safe-area-context": "4.6.3",
    "react-native-screens": "~3.22.0",
    "react-native-svg": "^13.9.0",
    "react-native-web": "~0.19.6"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.14",
    "jest": "^29.2.1",
    "jest-expo": "~49.0.0",
    "react-native-codegen": "^0.71.5",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.1.3"
  },
  "overrides": {
    "react-refresh": "~0.14.0"
  },
  "resolutions": {
    "react-refresh": "~0.14.0"
  },
  "eslintConfig": {
    "ignorePatterns": [
      "node_modules",
      "build",
      ".expo",
      ".expo-shared"
    ],
    "overrides": [
      {
        "files": [
          "*.js",
          "*.ts",
          "*.tsx",
          "*.jsx"
        ],
        "env": {
          "node": true
        },
        "rules": {
          "@typescript-eslint/explicit-module-boundary-types": [
            "off"
          ],
          "@typescript-eslint/explicit-function-return-type": [
            "off"
          ],
          "react-native/no-inline-styles": [
            "off"
          ]
        }
      }
    ]
  }
}
