{
  "name": "monorepo",
  "private": true,
  "workspaces": [
    "docs",
    "examples/*",
    "package",
    "scripts"
  ],
  "scripts": {
    "codegen": "yarn scripts codegen",
    "format": "prettier --write .",
    "lint": "yarn all-workspaces lint",
    "lint:tsc": "yarn all-workspaces lint:tsc",
    "lint:eslint": "yarn all-workspaces lint:eslint",
    "lint:eslint:fix": "yarn all-workspaces lint:eslint:fix",
    "docs": "yarn workspace docs",
    "all-workspaces": "yarn workspaces foreach --all --exclude monorepo --parallel --interlaced run",
    "examples:shared": "yarn workspace @maplibre-react-native/examples",
    "examples:react-native": "yarn workspace react-native-app",
    "examples:expo": "yarn workspace expo-app",
    "package": "yarn workspace @maplibre/maplibre-react-native",
    "scripts": "yarn workspace scripts"
  },
  "packageManager": "yarn@4.10.3"
}
